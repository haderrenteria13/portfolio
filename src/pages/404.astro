---
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="404 — Página no encontrada | Hader Renteria"
	description="Esta página no existe. Vuelve al portfolio de Hader Renteria."
>
	<section>
		<h1>404</h1>
		<h2>Esta página no existe</h2>
		<p>Parece que te perdiste. No hay nada aquí.</p>
		<a href="/">Volver al inicio</a>
	</section>

	<style>
		@keyframes fadeUpBlur {
			from {
				opacity: 0;
				transform: translateY(20px);
				filter: blur(8px);
			}
			to {
				opacity: 1;
				transform: translateY(0);
				filter: blur(0);
			}
		}

		section {
			display: flex;
			flex-direction: column;
			align-items: center;
			justify-content: center;
			height: 100vh;
			text-align: center;
			gap: 16px;
		}

		h1 {
			font-size: 90px;
			font-weight: 500;
			margin: 0;
			line-height: 1;
			opacity: 0;
			animation: fadeUpBlur 0.8s cubic-bezier(0.22, 1, 0.36, 1) 0.1s forwards;
		}

		h2 {
			font-size: 24px;
			font-weight: 400;
			margin: 0;
			color: #aeaeb2;
			opacity: 0;
			animation: fadeUpBlur 0.8s cubic-bezier(0.22, 1, 0.36, 1) 0.25s forwards;
		}

		p {
			font-size: 17px;
			font-weight: 400;
			margin: 0;
			color: #c7c7cc;
			opacity: 0;
			animation: fadeUpBlur 0.8s cubic-bezier(0.22, 1, 0.36, 1) 0.35s forwards;
		}

		a {
			padding: 14px 72px;
			font-size: 15px;
			border: none;
			border-radius: 100px;
			cursor: pointer;
			font-weight: 500;
			text-decoration: none;
			transition: all 0.35s cubic-bezier(0.22, 1, 0.36, 1);
			position: relative;
			overflow: hidden;
			letter-spacing: 0.01em;
			background-color: #1c1c1e;
			color: #ffffff;
			box-shadow: 0 2px 8px rgba(0, 0, 0, 0.12);
			opacity: 0;
			animation: fadeUpBlur 0.8s cubic-bezier(0.22, 1, 0.36, 1) 0.5s forwards;
		}

		a:hover {
			background-color: #000;
			box-shadow: 0 4px 16px rgba(0, 0, 0, 0.2);
			transform: translateY(-1px);
		}

		a:active {
			transform: scale(0.97);
		}
	</style>
</Layout>
