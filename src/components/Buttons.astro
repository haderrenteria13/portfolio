<div class="buttons">
	<a class="contactar" href="mailto:haderrenteria13az@gmail.com">Contactar</a>
	<a class="cv" href="/HaderRenteriaCV.pdf" target="_blank">Ver CV</a>
</div>

<style>
	:root {
		--accent: #0071e3;
		--accent-secondary: #0066cc;
	}
	.buttons {
		position: fixed;
		bottom: 36px;
		left: 50%;
		transform: translateX(-50%) translateY(20px);
		display: flex;
		gap: 12px;
		z-index: 100;
		padding: 6px;
		border-radius: 100px;
		background: rgba(255, 255, 255, 0.65);
		backdrop-filter: saturate(180%) blur(20px);
		-webkit-backdrop-filter: saturate(180%) blur(20px);
		border: 1px solid rgba(0, 0, 0, 0.05);
		box-shadow: 0 1px 10px rgba(0, 0, 0, 0.05);
		opacity: 0;
		pointer-events: none;
		transition: opacity 0.5s cubic-bezier(0.22, 1, 0.36, 1), transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
	}

	.buttons.is-visible {
		opacity: 1;
		transform: translateX(-50%) translateY(0);
		pointer-events: auto;
	}

	.buttons a {
		display: inline-block;
		padding: 11px 39px;
		font-size: 17px;
		color: white;
		border-radius: 980px;
		font-weight: 400;
		font-family: 'SF Pro Display', sans-serif;
		text-decoration: none;
		transition: transform 0.3s ease;
	}

	.buttons a:hover {
		opacity: 0.8;
		transform: translateY(-2px);
	}

	.buttons .contactar {
		background-color: transparent;
		color: var(--accent-secondary);
		border: 1px solid var(--accent-secondary);
	}

	.buttons .cv {
		background-color: var(--accent);
		border: 1px solid transparent; 
	}

	@keyframes buttonsSlideUp {
		from {
			opacity: 0;
			transform: translateX(-50%) translateY(20px);
		}
		to {
			opacity: 1;
			transform: translateX(-50%) translateY(0);
		}
	}

	@media (max-width: 900px) {
		.buttons {
			bottom: 24px;
		}

		.buttons a {
			padding: 12px 36px;
			font-size: 14px;
			white-space: nowrap;
		}
	}

	@media (max-width: 480px) {
		.buttons {
			bottom: 16px;
			padding: 4px;
			gap: 4px;
		}

		.buttons a {
			padding: 11px 20px;
			font-size: 13px;
		}
	}

	@media (max-width: 360px) {
		.buttons {
			padding: 3px;
			gap: 3px;
		}

		.buttons a {
			padding: 10px 16px;
			font-size: 12px;
		}
	}
</style>

<script>
	function setupButtonsVisibility() {
		const buttons = document.querySelector('.buttons');
		if (!buttons) return;

		const handleScroll = () => {
			if (window.scrollY > window.innerHeight * 0.5) {
				buttons.classList.add('is-visible');
			} else {
				buttons.classList.remove('is-visible');
			}
		};

		handleScroll();

		window.addEventListener('scroll', handleScroll, { passive: true });
	}
	document.addEventListener('astro:page-load', setupButtonsVisibility);
	
	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', setupButtonsVisibility);
	} else {
		setupButtonsVisibility();
	}
</script>
