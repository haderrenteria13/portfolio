---
import Projects from './Projects.astro';
---

<div id="projects" class="section">
	<main class="section-inner">
		<Projects />
		<section id="hero">
			<h1>Ideas que cobraron vida.</h1>
			<h2>Detrás de cada línea de código hay un problema resuelto y una historia que contar. Estos son mis proyectos favoritos. Haz clic en ellos para explorar los detalles y el proceso.</h2>
		</section>
	</main>
</div>

<style>
	@keyframes heroReveal {
		from {
			opacity: 0;
			transform: translateY(20px);
			filter: blur(8px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
			filter: blur(0);
		}
	}

	.section {
		--text-primary: #1d1d1f;
		--text-secondary: #aeaeb2;
		--site-gutter: 48px;
		
		padding: 140px 0;
		position: relative;
		scroll-margin-top: -60px;
	}

	.section-inner {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 var(--site-gutter);
		display: flex;
		justify-content: space-between;
		align-items: center;
	}

	#hero {
		display: flex;
		align-items: start;
		flex-direction: column;
		justify-content: center;
		transition: opacity 0.35s ease, filter 0.35s ease;
		max-width: 600px;
		width: 100%;
	}

	main:has(.has-image:hover) #hero {
		opacity: 0.08;
		filter: blur(6px);
	}

	h1 {
		font-size: 70px;
		font-weight: 500;
		letter-spacing: -0.015em;
		margin: 0;
		line-height: 1.05;
		opacity: 0;
		animation: heroReveal 0.8s cubic-bezier(0.22, 1, 0.36, 1) 0.25s forwards;
	}

	h2 {
		margin: 16px 0 0 0;
		font-weight: 400;
		color: #aeaeb2;
		font-size: 24px;
		line-height: 1.4;
		opacity: 0;
		animation: heroReveal 0.8s cubic-bezier(0.22, 1, 0.36, 1) 0.4s forwards;
	}


	@media (max-width: 768px) {
		.section {
			--site-gutter: 20px;
			padding: 72px 0;
		}

		.section-inner {
			flex-direction: column-reverse;
			gap: 48px;
			height: auto;
			min-height: 100%;
			justify-content: center;
			align-items: center;
		}

		#hero {
			align-items: center;
			text-align: center;
			width: 100%;
		}

		h1 {
			font-size: 38px;
		}

		h2 {
			font-size: 16px;
		}
	}
</style>
