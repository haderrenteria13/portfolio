---
import { Image } from 'astro:assets';
import haderImg from '../assets/Images/hader.png';
---

<section id="about" class="section section-about" aria-labelledby="about-title">
	<div class="section-inner">
		<h2 class="section-title reveal-element" id="about-title">Un poco más sobre mí.</h2>
        <div class="about-layout">
            <div class="about-content">
                <p class="about-text reveal-element">
                    Soy desarrollador de software con más de 2 años construyendo aplicaciones móviles y web. Trabajo con <strong>React</strong>, <strong>React Native</strong> y <strong>Node.js</strong> para transformar ideas en productos digitales que la gente realmente usa.
                </p>
            </div>
            <div class="about-image-wrapper reveal-element image-reveal">
                <Image src={haderImg} alt="Hader Renteria" class="about-image" width={720} height={800} loading="lazy" decoding="async" format="webp" quality={90} />
            </div>
        </div>
	</div>
</section>

<style>
	.section {
		--text-primary: #1d1d1f;
		--text-secondary: #aeaeb2;
        --background-color: #f5f5f7;
		--site-gutter: 48px;
		
		padding: 140px 0;
		position: relative;
		z-index: 100;
        scroll-margin-top: -60px;
	}

	.section-inner {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 var(--site-gutter);
        display: flex;
        flex-direction: column;
	}

	.section-title {
		font-size: clamp(40px, 6vw, 48px);
		font-weight: 500;
		letter-spacing: -0.015em;
		margin-bottom: 24px;
		color: var(--text-primary);
	}

    .about-layout {
        display: flex;
        background-color: var(--background-color);
        border-radius: 32px;
        flex-direction: column;
        align-items: center;
        gap: 40px;
        width: 100%;
        padding: 40px 40px 0 40px;
        overflow: hidden;
    }

    @media (min-width: 768px) {
        .about-layout {
            flex-direction: row;
            justify-content: space-between;
            align-items: flex-end;
            text-align: left;
            gap: 60px;
        }

        .about-content {
            flex: 1;
            order: 1;
            padding-bottom: 40px;
        }

        .about-image-wrapper {
            flex: 1;
            order: 2;
            display: flex;
            justify-content: center;
        }
    }

    .about-content {
        max-width: 100%;
    }

    .about-image-wrapper {
        width: 100%;
        max-width: 360px;
    }

    .about-image {
        width: 90%;
        height: auto;
        display: block;
        margin: 0 auto;
        object-fit: cover;
        -webkit-mask-image: linear-gradient(to bottom, rgba(0,0,0,1) 50%, rgba(0,0,0,0) 100%);
        mask-image: linear-gradient(to bottom, rgba(0,0,0,1) 50%, rgba(0,0,0,0) 100%);
        transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.6s cubic-bezier(0.22, 1, 0.36, 1);
    }

    .about-text {
        font-size: clamp(20px, 3.5vw, 26px);
        line-height: 1.5;
        font-weight: 400;
        color: var(--text-secondary);
        margin: 0;
    }

    .about-text strong {
        color: var(--text-primary);
        font-weight: 500;
    }

    .reveal-element {
        opacity: 0;
        transform: translateY(20px);
        filter: blur(8px);
        transition: opacity 0.8s cubic-bezier(0.22, 1, 0.36, 1), 
                    transform 0.8s cubic-bezier(0.22, 1, 0.36, 1), 
                    filter 0.8s cubic-bezier(0.22, 1, 0.36, 1);
        will-change: transform, opacity, filter;
    }

    .reveal-element.is-visible {
        opacity: 1;
        transform: translateY(0);
        filter: blur(0);
    }

    .about-text.reveal-element {
        transition-delay: 0.1s;
    }

    .image-reveal.reveal-element {
        transition-delay: 0.25s;
    }

	@media (max-width: 768px) {
		.section {
			--site-gutter: 20px;
			padding: 72px 0;
		}

		.section-title {
			margin-bottom: 32px;
		}

        .about-layout {
            padding: 32px 24px 0 24px;
            gap: 32px;
			text-align: center;
        }

        .about-image-wrapper {
            max-width: 240px;
        }
	}
</style>

<script>
    function setupReveal() {
        const elements = document.querySelectorAll('.section-about .reveal-element');
        
        if (elements.length === 0) return;

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('is-visible');
                    observer.unobserve(entry.target);
                }
            });
        }, {
            threshold: 0.1,
            rootMargin: '0px 0px -50px 0px'
        });

        elements.forEach(el => observer.observe(el));
    }

    document.addEventListener('DOMContentLoaded', setupReveal);
    document.addEventListener('astro:page-load', setupReveal);
</script>